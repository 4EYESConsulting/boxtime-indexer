# Ergo node API URL
# - Local node (docker-compose):  NODE_URL=http://node:9053
# - External node:                NODE_URL=https://your-ergo-node:9053
NODE_URL=http://node:9053

# PostgreSQL connection string
# - Local DB (docker-compose):    DATABASE_URL=postgresql://boxtime:boxtime@db:5432/boxtime
# - Supabase (use the pooler):    DATABASE_URL=postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres
# - Other remote Postgres:        DATABASE_URL=postgresql://user:pass@host:5432/dbname?sslmode=require
DATABASE_URL=postgresql://boxtime:boxtime@db:5432/boxtime

# Heights per batch during backfill
CHUNK_SIZE=5000

# Maximum concurrent requests to the node
MAX_CONCURRENT=50

# Seconds between chain-tip checks after backfill
POLL_INTERVAL=60

# Height to start from if DB is empty
START_HEIGHT=1
