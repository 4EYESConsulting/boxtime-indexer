# Ergo node API URL (default points to the local docker-compose node)
NODE_URL=http://node:9053

# PostgreSQL connection string
DATABASE_URL=postgresql://boxtime:boxtime@db:5432/boxtime

# Heights per batch during backfill
CHUNK_SIZE=5000

# Maximum concurrent requests to the node
MAX_CONCURRENT=50

# Seconds between chain-tip checks after backfill
POLL_INTERVAL=60

# Height to start from if DB is empty
START_HEIGHT=1
