# Ergo node API URL
# - Local node (docker-compose):  NODE_URL=http://node:9053
# - External node:                NODE_URL=https://your-ergo-node:9053
NODE_URL=http://node:9053

# Path to price CSV (downloaded from CoinGecko)
PRICE_CSV_PATH=input/erg_prices.csv

# Path to optional bootstrap CSV (previous output for incremental updates)
BOOTSTRAP_CSV_PATH=input/cointime.csv

# Path for output CSV
CSV_OUTPUT_PATH=output/cointime.csv

# Heights per batch during backfill
CHUNK_SIZE=5000

# Maximum concurrent requests to the node
MAX_CONCURRENT=50

# Requested height to start from if no bootstrap data (network fetch is clamped to >=1)
START_HEIGHT=1
